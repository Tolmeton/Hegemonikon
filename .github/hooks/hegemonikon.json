{
    "description": "Hegemonikon cognitive hooks — `.claude/settings.json` のフック構成を `hooks/` スクリプトへ整合させた JSON ミラー",
    "hooks": {
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/hooks/hgk-session-init.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/hooks/sekisho-gate-verify.sh"
                    }
                ]
            },
            {
                "matcher": "compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/hooks/hyphe-postcompact.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/hooks/n04-bash-guard.sh"
                    }
                ]
            },
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/hooks/n01-file-guard.sh"
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/hooks/hyphe-precompact.sh"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/hooks/n07-stop-guard.sh"
                    },
                    {
                        "type": "command",
                        "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/sekisho-l0-precheck.py",
                        "timeout": 10
                    },
                    {
                        "type": "command",
                        "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/sekisho-async-audit.py",
                        "timeout": 15
                    },
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/hooks/export-transcript.sh",
                        "timeout": 15
                    },
                    {
                        "type": "command",
                        "command": "python3 \"$CLAUDE_PROJECT_DIR\"/hooks/pinakas-collector.py",
                        "timeout": 15
                    }
                ]
            }
        ]
    }
}
