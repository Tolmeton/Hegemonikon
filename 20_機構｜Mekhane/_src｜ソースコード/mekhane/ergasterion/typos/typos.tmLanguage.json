{
  "name": "Typos v8",
  "scopeName": "source.typos",
  "fileTypes": ["typos"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#meta-header" },
    { "include": "#code-block" },
    { "include": "#inline-directive" },
    { "include": "#block-open" },
    { "include": "#named-close" },
    { "include": "#anon-close" },
    { "include": "#table-delimiter" },
    { "include": "#flow-directive" },
    { "include": "#identifier" },
    { "include": "#confidence-label" },
    { "include": "#section-separator" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*//.*$",
      "name": "comment.line.double-slash.typos"
    },
    "meta-header": {
      "patterns": [
        {
          "match": "^#(prompt)\\s+(.+)$",
          "captures": {
            "1": { "name": "keyword.control.typos" },
            "2": { "name": "entity.name.tag.typos" }
          },
          "name": "meta.header.prompt.typos"
        },
        {
          "match": "^#(syntax|depth|target|canonical|archive|mixin)\\s*:\\s*(.+)$",
          "captures": {
            "1": { "name": "keyword.control.typos" },
            "2": { "name": "string.unquoted.typos" }
          },
          "name": "meta.header.typos"
        }
      ]
    },
    "code-block": {
      "begin": "^\\s*```",
      "end": "^\\s*```",
      "name": "markup.fenced_code.block.typos",
      "contentName": "meta.embedded.block.typos"
    },
    "inline-directive": {
      "match": "<:(\\w[\\w-]*):\\s*(.*?)\\s*:>",
      "captures": {
        "1": { "name": "entity.name.tag.typos" },
        "2": { "name": "string.unquoted.typos" }
      },
      "name": "meta.directive.inline.typos"
    },
    "block-open": {
      "match": "^\\s*<:(\\w[\\w-]*):",
      "captures": {
        "1": { "name": "entity.name.tag.typos" }
      },
      "name": "keyword.control.directive.open.typos"
    },
    "named-close": {
      "match": "^\\s*/(\\w[\\w-]*):>",
      "captures": {
        "1": { "name": "entity.name.tag.typos" }
      },
      "name": "keyword.control.directive.close.typos"
    },
    "anon-close": {
      "match": "^\\s*:>\\s*$",
      "name": "keyword.control.directive.close.typos"
    },
    "table-delimiter": {
      "match": "::",
      "name": "punctuation.separator.table.typos"
    },
    "flow-directive": {
      "match": ">>",
      "name": "keyword.operator.flow.typos"
    },
    "identifier": {
      "match": "<:([A-Z]-\\d[\\w.]*):>",
      "captures": {
        "1": { "name": "constant.other.identifier.typos" }
      },
      "name": "meta.identifier.typos"
    },
    "confidence-label": {
      "match": "\\[(確信|推定|仮説)\\]",
      "name": "markup.bold.confidence.typos"
    },
    "section-separator": {
      "match": "^//\\s*─+.*─+\\s*$",
      "name": "comment.line.separator.typos"
    }
  }
}
